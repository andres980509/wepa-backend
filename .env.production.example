APP_ENV=production
APP_PORT=8080

DB_URL=jdbc:postgresql://postgres:5432/wepa
DB_USER=wepa
DB_PASSWORD=CAMBIAR_PASSWORD_PRODUCCION
DB_POOL_MAX_SIZE=30
DB_POOL_MIN_IDLE=5
DB_MIGRATIONS_ENABLED=true

JWT_SECRET=CAMBIAR_SECRET_PRODUCCION_MINIMO_32_CHARS
JWT_ACCESS_TTL_MS=14400000
JWT_MOBILE_ACCESS_TTL_MS=1800000
JWT_REFRESH_TTL_DAYS=30

UPLOAD_BASE_DIR=/var/wepa/uploads
UPLOAD_MAX_FILE_SIZE_BYTES=10485760
WEPA_PUBLIC_UPLOADS_ENABLED=false
DOCUMENT_STORAGE_PROVIDER=local

WEPA_BOOTSTRAP_ADMIN_ENABLED=false

WOMPI_CHECKOUT_URL=
WOMPI_WEBHOOK_SECRET=CAMBIAR_WEBHOOK_SECRET_WOMPI
WOMPI_PUBLIC_KEY=
WOMPI_PRIVATE_KEY=

EPAYCO_CHECKOUT_URL=
EPAYCO_WEBHOOK_SECRET=CAMBIAR_WEBHOOK_SECRET_EPAYCO
EPAYCO_PUBLIC_KEY=
EPAYCO_PRIVATE_KEY=

MERCADOPAGO_WEBHOOK_SECRET=CAMBIAR_WEBHOOK_SECRET_MERCADOPAGO
MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_API_BASE_URL=https://api.mercadopago.com
MERCADOPAGO_NOTIFICATION_URL=
MERCADOPAGO_SUCCESS_URL=https://tu-dominio.com/finanzas/pagos?status=success
MERCADOPAGO_FAILURE_URL=https://tu-dominio.com/finanzas/pagos?status=failure
MERCADOPAGO_PENDING_URL=https://tu-dominio.com/finanzas/pagos?status=pending
MERCADOPAGO_AUTO_RETURN_ENABLED=true
MERCADOPAGO_CHECKOUT_URL_MODE=init_point
MERCADOPAGO_LINK_EXPIRATION_MINUTES=60
MERCADOPAGO_PSE_LINK_EXPIRATION_MINUTES=4320
MERCADOPAGO_CLEANUP_EXPIRATION_MINUTES=5
WEPA_PUBLIC_BASE_URL=https://api.tu-dominio.com
